
config server 'server'
	option enabled '0'
	option port '1194'
	option proto 'tcp'
	option ipv6 '1'
	option dev 'ovpn_server'
	option ip_segment '172.30.1.0'
	option subnet_mask '255.255.255.0'
	option lzo '1'
	option redirect_gateway '1'
	option client_to_client '1'
	option masquerade '1'
	option allow_lan '1'
	option keepalive_interval '10'
	option keepalive_timeout '120'
	option verb '3'
	option auth_method 'password'
	option cipher 'AES-256-GCM'
	option auth 'SHA256'
	option tls_crypt '0'
	option tls_auth '0'
	option duplicate_cn '0'
	option ddns 'example.com'
	option ovpn_name 'openvpn'
	option client_lzo '1'
